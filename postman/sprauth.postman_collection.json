{
  "info": {
    "_postman_id": "b6f4a3d2-8e1c-4c2a-9f0a-3d5e7c1a9b21",
    "name": "Sprauth",
    "description": "Passwordless, post-quantum (ML-DSA-65) challenge-response authentication API.\n\nFlow:\n1. POST /challenge/init to get a server-signed challenge.\n2. Sign the decoded `challenge` string from that token with your client ML-DSA-65 private key (Postman cannot do this natively — see the `signature` / `clientPublicKey` variable notes below).\n3. POST /challenge/verify (just checks the proof) or POST /auth (checks the proof and also mints access/refresh tokens).\n\nCollection variables are used throughout so requests can be chained without manual copy/paste; several requests have test scripts that populate them automatically from responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "identity", "value": "pqc1REPLACE_WITH_CLIENT_ADDRESS", "type": "string" },
    { "key": "intent", "value": "login", "type": "string" },
    { "key": "clientPublicKey", "value": "REPLACE_WITH_CLIENT_PUBLIC_KEY_BASE64", "type": "string" },
    { "key": "signature", "value": "REPLACE_WITH_SIGNATURE_BASE64", "type": "string" },
    { "key": "challengeJwt", "value": "", "type": "string" },
    { "key": "tokenId", "value": "", "type": "string" },
    { "key": "challengeString", "value": "", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "sessionId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Security",
      "item": [
        {
          "name": "Get Server Public Key",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sec/key/public",
              "host": ["{{baseUrl}}"],
              "path": ["sec", "key", "public"]
            },
            "description": "Returns the server's ML-DSA-65 public key, base64-encoded. Used to verify server-signed tokens independently of this API."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Challenge",
      "item": [
        {
          "name": "Init Challenge",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('challengeJwt', body.challengeToken);",
                  "",
                  "const payloadB64Url = body.challengeToken.split('.')[1];",
                  "const payloadB64 = payloadB64Url.replace(/-/g, '+').replace(/_/g, '/');",
                  "const decoded = JSON.parse(atob(payloadB64));",
                  "",
                  "pm.collectionVariables.set('tokenId', decoded.tokenId);",
                  "pm.collectionVariables.set('challengeString', decoded.challenge);",
                  "",
                  "pm.test('challengeToken returned', () => pm.expect(body.challengeToken).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identity\": \"{{identity}}\",\n  \"intent\": \"{{intent}}\",\n  \"customClaims\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/challenge/init",
              "host": ["{{baseUrl}}"],
              "path": ["challenge", "init"]
            },
            "description": "Issues a server-signed, single-use challenge for `identity`. Stores `tokenId` in Redis with a TTL. Populates `challengeJwt`, `tokenId`, and `challengeString` collection variables on success.\n\n`customClaims` is spread into the token payload before reserved fields (`iat`, `identity`, `intent`, `challenge`, `tokenId`), so it cannot override them."
          },
          "response": []
        },
        {
          "name": "Check Challenge Valid",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/challenge/valid?tokenId={{tokenId}}",
              "host": ["{{baseUrl}}"],
              "path": ["challenge", "valid"],
              "query": [{ "key": "tokenId", "value": "{{tokenId}}" }]
            },
            "description": "Checks whether a challenge's tokenId is still pending (unconsumed) in Redis. Run this before Verify Challenge / Authenticate to confirm it hasn't expired or already been used."
          },
          "response": []
        },
        {
          "name": "Verify Challenge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"challengeJwt\": \"{{challengeJwt}}\",\n  \"signature\": \"{{signature}}\",\n  \"publicKey\": \"{{clientPublicKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/challenge/verify",
              "host": ["{{baseUrl}}"],
              "path": ["challenge", "verify"]
            },
            "description": "Verifies the server-signed challenge and the client's proof-of-possession signature over `challengeString`, without issuing tokens. Consumes the challenge (single use) regardless of outcome.\n\n`signature` = ML-DSA-65 signature over the raw `challengeString` bytes, produced with the client's private key.\n`publicKey` = the client's ML-DSA-65 public key (base64); its derived `pqc1...` address must match `identity`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Authenticate",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "}",
                  "",
                  "pm.test('challengePassed reflected in response', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('challengePassed');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"challengeJwt\": \"{{challengeJwt}}\",\n  \"signature\": \"{{signature}}\",\n  \"publicKey\": \"{{clientPublicKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", ""]
            },
            "description": "Same verification as Verify Challenge, but on success mints `accessToken` and `refreshToken` (self-issued, ML-DSA-signed) instead of just a boolean. Consumes the challenge (single use) regardless of outcome.\n\nNote: uses the same challenge JWT as Verify Challenge — a challenge can only be redeemed once, by whichever of the two endpoints you call first."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Session",
      "item": [
        {
          "name": "Start Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('sessionId', pm.response.json().sessionId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identity\": \"{{identity}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/session/start",
              "host": ["{{baseUrl}}"],
              "path": ["session", "start"]
            },
            "description": "Creates a new Redis-backed session for `identity` with a server-generated `sessionId`. Populates the `sessionId` collection variable on success.\n\nNote: not currently called as part of Authenticate — sessions here are independent of access/refresh token issuance."
          },
          "response": []
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/session/?identity={{identity}}",
              "host": ["{{baseUrl}}"],
              "path": ["session", ""],
              "query": [{ "key": "identity", "value": "{{identity}}" }]
            },
            "description": "Lists all active session IDs for `identity`."
          },
          "response": []
        },
        {
          "name": "Check Session Valid",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/session/valid?identity={{identity}}&sessionId={{sessionId}}&renewTtl=false",
              "host": ["{{baseUrl}}"],
              "path": ["session", "valid"],
              "query": [
                { "key": "identity", "value": "{{identity}}" },
                { "key": "sessionId", "value": "{{sessionId}}" },
                { "key": "renewTtl", "value": "false", "description": "set to true to renew the session TTL on check" }
              ]
            },
            "description": "Checks whether a specific session is still valid, optionally renewing its TTL."
          },
          "response": []
        },
        {
          "name": "End Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identity\": \"{{identity}}\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/session/end",
              "host": ["{{baseUrl}}"],
              "path": ["session", "end"]
            },
            "description": "Ends a single session (e.g. logout on one device)."
          },
          "response": []
        },
        {
          "name": "Revoke Other Sessions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identity\": \"{{identity}}\",\n  \"except\": [\"{{sessionId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/session/revoke",
              "host": ["{{baseUrl}}"],
              "path": ["session", "revoke"]
            },
            "description": "Ends all of `identity`'s sessions except the ones listed in `except` (e.g. \"log out everywhere else\"). Pass an empty array to end every session."
          },
          "response": []
        }
      ]
    }
  ]
}
